# Helper function to format currency
format_rupiah <- function(x) {
  if(is.na(x) || x == 0) return("Rp 0")
  formatted <- format(round(x), big.mark = ".", decimal.mark = ",", scientific = FALSE)
  formatted <- gsub("\\.00$", "", formatted)
  formatted <- gsub(",00$", "", formatted)
  return(paste0("Rp ", formatted))
}

# Function to calculate discount
calculate_discount <- function(quantity, price) {
  if(quantity > 500) {
    discount <- price * quantity * 0.05
    return(list(discount = discount, has_discount = TRUE))
  } else {
    return(list(discount = 0, has_discount = FALSE))
  }
}

calculate_ppn_tax <- function(amount) {
  return(amount * 0.11)
}

# Define Server
server <- function(input, output, session) {
  
  # Reactive values
  values <- reactiveValues(
    current_purchase = data.frame(
      Kode = character(), Barang = character(), Harga = numeric(),
      Quantity = numeric(), Discount = numeric(), Discount_Amount = numeric(),
      After_Discount = numeric(), stringsAsFactors = FALSE
    ),
    all_purchases = list(),
    current_return = data.frame(
      Barang = character(), Rusak = numeric(), Rusak_Parsial = numeric(),
      Harga = numeric(), Total_Refund = numeric(), stringsAsFactors = FALSE
    ),
    return_list = list(),
    last_processed_return = NULL,
    current_purchase_data = NULL,
    editing_invoice = NULL,
    received_quantities = list(),
    updating = FALSE,
    trigger = 0
  )
  
  # Helper functions
  get_received_quantity <- function(invoice_no, item_name, original_qty) {
    if(!is.null(values$received_quantities[[invoice_no]]) && 
       !is.null(values$received_quantities[[invoice_no]][[item_name]])) {
      return(values$received_quantities[[invoice_no]][[item_name]])
    }
    return(original_qty)
  }
  
  get_returned_quantity <- function(invoice_no, item_name) {
    if(is.null(values$return_list[[invoice_no]])) return(0)
    return_data <- values$return_list[[invoice_no]]
    if(item_name %in% return_data$Return_Items$Barang) {
      idx <- which(return_data$Return_Items$Barang == item_name)
      return(return_data$Return_Items$Rusak[idx] + return_data$Return_Items$Rusak_Parsial[idx])
    }
    return(0)
  }
  
  calculate_invoice_payment <- function(invoice_no) {
    if(is.null(values$all_purchases[[invoice_no]])) {
      return(list(subtotal=0, discount=0, ppn=0, total=0, items_detail=list()))
    }
    
    purchase_data <- values$all_purchases[[invoice_no]]
    items <- purchase_data$Barang
    total_received_value <- 0
    total_discount <- 0
    items_detail <- list()
    
    for(i in 1:nrow(items)) {
      item <- items[i, ]
      original_qty <- item$Quantity
      harga <- item$Harga
      
      received_qty <- get_received_quantity(invoice_no, item$Barang, original_qty)
      returned_qty <- get_returned_quantity(invoice_no, item$Barang)
      
      if(received_qty + returned_qty > original_qty) {
        received_qty <- original_qty - returned_qty
        if(received_qty < 0) received_qty <- 0
      }
      
      item_total <- received_qty * harga
      
      discount_amount <- 0
      if(original_qty > 500) {
        discount_amount <- item_total * 0.05
        total_discount <- total_discount + discount_amount
        item_total <- item_total - discount_amount
      }
      
      total_received_value <- total_received_value + item_total
      
      items_detail[[item$Barang]] <- list(
        original_qty = original_qty,
        received_qty = received_qty,
        returned_qty = returned_qty,
        price = harga,
        item_total = item_total,
        discount = discount_amount
      )
    }
    
    ppn <- total_received_value * 0.11
    total_payment <- total_received_value + ppn
    
    return(list(
      subtotal = total_received_value,
      discount = total_discount,
      ppn = ppn,
      total = total_payment,
      items_detail = items_detail
    ))
  }
  
  calculate_total_refund <- function(invoice_no) {
    if(is.null(values$return_list[[invoice_no]])) return(0)
    return(sum(values$return_list[[invoice_no]]$Return_Items$Total_Refund))
  }
  
  refresh_dropdowns <- function() {
    choices_list <- names(values$all_purchases)
    if(length(choices_list) == 0) choices_list <- c("")
    updateSelectInput(session, "select_invoice_return", choices = choices_list)
  }
  
  initialize_received_quantities <- function(invoice_no) {
    if(is.null(values$all_purchases[[invoice_no]])) return()
    
    purchase_data <- values$all_purchases[[invoice_no]]
    if(is.null(values$received_quantities[[invoice_no]])) {
      values$received_quantities[[invoice_no]] <- list()
    }
    
    for(i in 1:nrow(purchase_data$Barang)) {
      item <- purchase_data$Barang[i, ]
      if(is.null(values$received_quantities[[invoice_no]][[item$Barang]])) {
        values$received_quantities[[invoice_no]][[item$Barang]] <- item$Quantity
      }
    }
  }
  
  update_received_quantity <- function(invoice_no, item_name, new_received_qty) {
    if(values$updating) return()
    values$updating <- TRUE
    
    if(!is.null(values$all_purchases[[invoice_no]])) {
      purchase_data <- values$all_purchases[[invoice_no]]
      original_qty <- purchase_data$Barang$Quantity[purchase_data$Barang$Barang == item_name]
      returned_qty <- get_returned_quantity(invoice_no, item_name)
      
      max_receive <- original_qty - returned_qty
      if(max_receive < 0) max_receive <- 0
      if(new_received_qty < 0) new_received_qty <- 0
      if(new_received_qty > max_receive) new_received_qty <- max_receive
      
      if(is.null(values$received_quantities[[invoice_no]])) {
        values$received_quantities[[invoice_no]] <- list()
      }
      
      values$received_quantities[[invoice_no]][[item_name]] <- new_received_qty
    }
    
    values$updating <- FALSE
    values$trigger <- values$trigger + 1
  }
  
  # Add barang
  observeEvent(input$add_barang, {
    if(input$kode_barang != "" && input$nama_barang != "" && input$harga_barang > 0) {
      discount_info <- calculate_discount(input$quantity_barang, input$harga_barang)
      after_discount <- (input$harga_barang * input$quantity_barang) - discount_info$discount
      
      new_row <- data.frame(
        Kode = input$kode_barang, Barang = input$nama_barang, Harga = input$harga_barang,
        Quantity = input$quantity_barang, Discount = ifelse(discount_info$has_discount, 5, 0),
        Discount_Amount = discount_info$discount, After_Discount = after_discount,
        stringsAsFactors = FALSE
      )
      values$current_purchase <- rbind(values$current_purchase, new_row)
      
      updateTextInput(session, "kode_barang", value = "")
      updateTextInput(session, "nama_barang", value = "")
      updateNumericInput(session, "harga_barang", value = 0)
      updateNumericInput(session, "quantity_barang", value = 1)
      
      showNotification("Barang berhasil ditambahkan", type = "message")
    } else {
      showNotification("Mohon lengkapi data barang", type = "warning")
    }
  })
  
  output$table_purchase <- renderTable({
    req(nrow(values$current_purchase) > 0)
    df <- values$current_purchase
    data.frame(
      Kode = df$Kode, Barang = df$Barang,
      Harga = sapply(df$Harga, format_rupiah),
      Quantity = df$Quantity,
      Diskon = ifelse(df$Discount > 0, paste0(df$Discount, "%"), "-"),
      Total = sapply(df$After_Discount, format_rupiah)
    )
  }, striped = TRUE, hover = TRUE, bordered = TRUE)
  
  # Save purchase
  observeEvent(input$save_purchase, {
    if(nrow(values$current_purchase) == 0) {
      showNotification("Tidak ada barang!", type = "warning")
      return()
    }
    if(input$nama_peminta == "") {
      showNotification("Isi Nama Peminta!", type = "warning")
      return()
    }
    
    values$all_purchases[[input$invoice_no]] <- list(
      Informasi = data.frame(
        Invoice = input$invoice_no, Tanggal = as.character(input$tanggal),
        Nama_Peminta = input$nama_peminta, stringsAsFactors = FALSE
      ),
      Barang = values$current_purchase
    )
    
    values$received_quantities[[input$invoice_no]] <- list()
    for(i in 1:nrow(values$current_purchase)) {
      item <- values$current_purchase[i, ]
      values$received_quantities[[input$invoice_no]][[item$Barang]] <- item$Quantity
    }
    
    refresh_dropdowns()
    values$trigger <- values$trigger + 1
    
    values$current_purchase <- data.frame(
      Kode = character(), Barang = character(), Harga = numeric(),
      Quantity = numeric(), Discount = numeric(), Discount_Amount = numeric(),
      After_Discount = numeric(), stringsAsFactors = FALSE
    )
    
    updateTextInput(session, "invoice_no", value = paste0("PR-", format(Sys.Date(), "%Y%m%d"), "-", 
                                                          sprintf("%03d", length(values$all_purchases) + 1)))
    updateTextInput(session, "nama_peminta", value = "")
    
    showNotification("Purchase berhasil disimpan!", type = "message")
  })
  
  # Reset form
  observeEvent(input$reset_form, {
    values$current_purchase <- data.frame(
      Kode = character(), Barang = character(), Harga = numeric(),
      Quantity = numeric(), Discount = numeric(), Discount_Amount = numeric(),
      After_Discount = numeric(), stringsAsFactors = FALSE
    )
    showNotification("Form telah direset", type = "message")
  })
  
  # Display saved purchases
  output$table_saved_purchases <- renderTable({
    req(length(values$all_purchases) > 0)
    summary_list <- list()
    for(inv in names(values$all_purchases)) {
      info <- values$all_purchases[[inv]]$Informasi
      payment <- calculate_invoice_payment(inv)
      refund <- calculate_total_refund(inv)
      final_amount <- payment$total - refund
      
      summary_list[[inv]] <- data.frame(
        Invoice = info$Invoice, Tanggal = info$Tanggal, Peminta = info$Nama_Peminta,
        Subtotal = format_rupiah(payment$subtotal), Diskon = format_rupiah(payment$discount),
        PPN_11 = format_rupiah(payment$ppn), Total_Dibayar = format_rupiah(final_amount),
        stringsAsFactors = FALSE
      )
    }
    do.call(rbind, summary_list)
  }, striped = TRUE, hover = TRUE, bordered = TRUE)
  
  # Manage UI
  output$manage_purchases_ui <- renderUI({
    req(length(values$all_purchases) > 0)
    rows <- lapply(names(values$all_purchases), function(inv) {
      info <- values$all_purchases[[inv]]$Informasi
      payment <- calculate_invoice_payment(inv)
      tags$tr(
        tags$td(info$Invoice), tags$td(info$Tanggal), tags$td(info$Nama_Peminta),
        tags$td(format_rupiah(payment$total)),
        tags$td(
          tags$button(class = "btn btn-warning btn-sm", style = "margin-right: 5px;",
                      onclick = sprintf("Shiny.setInputValue('edit_invoice', '%s', {priority: 'event'})", inv), "✏️ Edit"),
          tags$button(class = "btn btn-danger btn-sm",
                      onclick = sprintf("if(confirm('Hapus purchase %s?')) Shiny.setInputValue('delete_invoice', '%s', {priority: 'event'})", inv, inv), "🗑️ Hapus")
        )
      )
    })
    tagList(
      tags$table(class = "table table-bordered table-striped",
                 tags$thead(tags$tr(tags$th("Invoice"), tags$th("Tanggal"), tags$th("Peminta"), tags$th("Total Akhir"), tags$th("Aksi"))),
                 tags$tbody(rows)
      )
    )
  })
  
  output$manage_returns_ui <- renderUI({
    req(length(values$return_list) > 0)
    rows <- lapply(names(values$return_list), function(inv) {
      info <- values$return_list[[inv]]$Informasi
      tags$tr(
        tags$td(info$Invoice), tags$td(info$Tanggal), tags$td(info$Peminta),
        tags$td(format_rupiah(info$Total_Refund)),
        tags$td(
          tags$button(class = "btn btn-danger btn-sm",
                      onclick = sprintf("if(confirm('Hapus return untuk %s?')) Shiny.setInputValue('delete_return_invoice', '%s', {priority: 'event'})", inv, inv), "🗑️ Hapus Return")
        )
      )
    })
    tagList(
      tags$table(class = "table table-bordered table-striped",
                 tags$thead(tags$tr(tags$th("Invoice"), tags$th("Tanggal"), tags$th("Peminta"), tags$th("Total Refund"), tags$th("Aksi"))),
                 tags$tbody(rows)
      )
    )
  })
  
  observeEvent(input$delete_invoice, {
    inv <- input$delete_invoice
    if(!is.null(inv) && inv %in% names(values$all_purchases)) {
      values$all_purchases[[inv]] <- NULL
      values$return_list[[inv]] <- NULL
      values$received_quantities[[inv]] <- NULL
      refresh_dropdowns()
      values$trigger <- values$trigger + 1
      showNotification(paste("Purchase", inv, "dihapus!"), type = "message")
    }
  })
  
  observeEvent(input$delete_return_invoice, {
    inv <- input$delete_return_invoice
    if(!is.null(inv) && inv %in% names(values$return_list)) {
      values$return_list[[inv]] <- NULL
      if(!is.null(values$all_purchases[[inv]])) {
        initialize_received_quantities(inv)
      }
      values$trigger <- values$trigger + 1
      showNotification(paste("Return untuk", inv, "dihapus!"), type = "message")
    }
  })
  
  observeEvent(input$edit_invoice, {
    inv <- input$edit_invoice
    if(!is.null(inv) && inv %in% names(values$all_purchases)) {
      purchase_data <- values$all_purchases[[inv]]
      showModal(modalDialog(
        title = paste("Edit Purchase -", inv), size = "l",
        textInput("edit_invoice_no", "No. Invoice", value = purchase_data$Informasi$Invoice),
        dateInput("edit_tanggal", "Tanggal", value = as.Date(purchase_data$Informasi$Tanggal)),
        textInput("edit_nama_peminta", "Nama Peminta", value = purchase_data$Informasi$Nama_Peminta),
        hr(), h4("Daftar Barang:"),
        renderTable({
          df <- purchase_data$Barang
          df$Harga <- sapply(df$Harga, format_rupiah)
          df$After_Discount <- sapply(df$After_Discount, format_rupiah)
          df[, c("Kode", "Barang", "Harga", "Quantity", "After_Discount")]
        }, striped = TRUE, hover = TRUE, bordered = TRUE),
        footer = tagList(
          actionButton("confirm_edit", "💾 Simpan Perubahan", class = "btn-success"),
          modalButton("Batal")
        )
      ))
      values$editing_invoice <- inv
    }
  })
  
  observeEvent(input$confirm_edit, {
    if(!is.null(values$editing_invoice) && values$editing_invoice %in% names(values$all_purchases)) {
      old_invoice <- values$editing_invoice
      new_invoice <- input$edit_invoice_no
      
      values$all_purchases[[old_invoice]]$Informasi$Tanggal <- as.character(input$edit_tanggal)
      values$all_purchases[[old_invoice]]$Informasi$Nama_Peminta <- input$edit_nama_peminta
      
      if(new_invoice != old_invoice) {
        values$all_purchases[[new_invoice]] <- values$all_purchases[[old_invoice]]
        values$all_purchases[[old_invoice]] <- NULL
        values$all_purchases[[new_invoice]]$Informasi$Invoice <- new_invoice
        
        if(!is.null(values$return_list[[old_invoice]])) {
          values$return_list[[new_invoice]] <- values$return_list[[old_invoice]]
          values$return_list[[old_invoice]] <- NULL
