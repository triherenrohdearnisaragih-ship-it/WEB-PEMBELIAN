  # Create observers for all inputs
  observeEvent(values$trigger, {
    req(length(values$all_purchases) > 0)
    
    # Initialize all received quantities
    for(inv in names(values$all_purchases)) {
      initialize_received_quantities(inv)
    }
    
    # Remove existing observers
    for(obs_name in names(session$userData)) {
      if(grepl("^qty_", obs_name) || grepl("^btn_", obs_name)) {
        if(!is.null(session$userData[[obs_name]])) {
          tryCatch({ session$userData[[obs_name]]$destroy() }, error = function(e) {})
        }
      }
    }
    
    session$userData <- list()
    
    # Create new observers for all items
    for(inv in names(values$all_purchases)) {
      purchase_data <- values$all_purchases[[inv]]
      items <- purchase_data$Barang
      
      for(i in 1:nrow(items)) {
        item <- items[i, ]
        safe_inv <- gsub("[^A-Za-z0-9]", "_", inv)
        safe_item <- gsub("[^A-Za-z0-9]", "_", item$Barang)
        
        local_inv <- inv
        local_item <- item$Barang
        local_item_qty <- item$Quantity
        local_returned <- get_returned_quantity(inv, item$Barang)
        local_max_receive <- local_item_qty - local_returned
        if(local_max_receive < 0) local_max_receive <- 0
        
        qty_input_id <- paste0("qty_", safe_inv, "_", safe_item)
        
        session$userData[[qty_input_id]] <- observeEvent(input[[qty_input_id]], {
          new_qty <- input[[qty_input_id]]
          if(!is.null(new_qty) && !is.na(new_qty)) {
            if(new_qty < 0) new_qty <- 0
            if(new_qty > local_max_receive) new_qty <- local_max_receive
            update_received_quantity(local_inv, local_item, new_qty)
          }
        }, ignoreInit = TRUE, ignoreNULL = FALSE)
        
        btn_lengkap_id <- paste0("btn_lengkap_", safe_inv, "_", safe_item)
        session$userData[[btn_lengkap_id]] <- observeEvent(input[[btn_lengkap_id]], {
          max_receive <- local_item_qty - get_returned_quantity(local_inv, local_item)
          if(max_receive < 0) max_receive <- 0
          update_received_quantity(local_inv, local_item, max_receive)
        }, ignoreInit = TRUE)
        
        btn_belum_lengkap_id <- paste0("btn_belum_lengkap_", safe_inv, "_", safe_item)
        session$userData[[btn_belum_lengkap_id]] <- observeEvent(input[[btn_belum_lengkap_id]], {
          max_receive <- local_item_qty - get_returned_quantity(local_inv, local_item)
          if(max_receive < 0) max_receive <- 0
          new_qty <- floor(max_receive * 0.5)
          update_received_quantity(local_inv, local_item, new_qty)
        }, ignoreInit = TRUE)
        
        btn_belum_diterima_id <- paste0("btn_belum_diterima_", safe_inv, "_", safe_item)
        session$userData[[btn_belum_diterima_id]] <- observeEvent(input[[btn_belum_diterima_id]], {
          update_received_quantity(local_inv, local_item, 0)
        }, ignoreInit = TRUE)
      }
    }
  })
  
  # Print return
  observeEvent(input$print_return, {
    if(is.null(values$last_processed_return)) {
      showNotification("Tidak ada return yang diproses!", type = "warning")
      return()
    }
    session$sendCustomMessage(type = 'print', message = list())
  })
  
  # Summary tables
  output$table_summary <- renderTable({
    req(length(values$all_purchases) > 0)
    summary_list <- list()
    for(inv in names(values$all_purchases)) {
      purchase_data <- values$all_purchases[[inv]]
      for(i in 1:nrow(purchase_data$Barang)) {
        item <- purchase_data$Barang[i, ]
        summary_list[[paste0(inv, i)]] <- data.frame(
          Invoice = inv, Barang = item$Barang, Quantity = item$Quantity,
          Harga = format_rupiah(item$Harga), Subtotal = format_rupiah(item$Harga * item$Quantity),
          Diskon = ifelse(item$Discount > 0, paste0(item$Discount, "%"), "-"),
          Setelah_Diskon = format_rupiah(item$After_Discount), stringsAsFactors = FALSE
        )
      }
    }
    do.call(rbind, summary_list)
  }, striped = TRUE, hover = TRUE, bordered = TRUE)
  
  output$table_return_summary <- renderTable({
    req(length(values$return_list) > 0)
    return_summary <- list()
    for(inv in names(values$return_list)) {
      return_data <- values$return_list[[inv]]
      for(i in 1:nrow(return_data$Return_Items)) {
        item <- return_data$Return_Items[i, ]
        return_summary[[paste0(inv, i)]] <- data.frame(
          Invoice = inv, Barang = item$Barang, `Rusak Total` = item$Rusak,
          `Rusak Parsial` = item$Rusak_Parsial,
          `Harga` = format_rupiah(item$Harga),
          `Total Refund` = format_rupiah(item$Total_Refund), stringsAsFactors = FALSE
        )
      }
    }
    if(length(return_summary) > 0) do.call(rbind, return_summary) else data.frame(Message = "Belum ada data return")
  }, striped = TRUE, hover = TRUE, bordered = TRUE)
  
  output$damage_summary <- renderPrint({
    req(length(values$return_list) > 0)
    for(inv in names(values$return_list)) {
      return_data <- values$return_list[[inv]]
      cat("\n=============================================================\n")
      cat("                 INVOICE PURCHASE RETURN\n")
      cat("=============================================================\n\n")
      cat("No. PR    :", return_data$Informasi$Invoice, "\n")
      cat("Tanggal   :", return_data$Informasi$Tanggal, "\n")
      cat("Peminta   :", return_data$Informasi$Peminta, "\n\n")
      cat("=============================================================\n\n")
      
      for(i in 1:nrow(return_data$Return_Items)) {
        item <- return_data$Return_Items[i, ]
        if(item$Rusak > 0) {
          cat("Nama Barang               :", item$Barang, "\n")
          cat("Kondisi Barang            : Rusak Total\n")
          cat("Jumlah Barang             :", item$Rusak, "\n")
          cat("Total Pengembalian Uang   :", format_rupiah(item$Rusak * item$Harga), "\n")
          cat("Next Step                 : Retur (Refund 100%)\n")
          cat("-------------------------------------------------------------\n")
        }
        if(item$Rusak_Parsial > 0) {
          cat("Nama Barang               :", item$Barang, "\n")
          cat("Kondisi Barang            : Rusak Parsial\n")
          cat("Jumlah Barang             :", item$Rusak_Parsial, "\n")
          cat("Total Pengembalian Uang   :", format_rupiah(item$Rusak_Parsial * item$Harga * 0.5), "\n")
          cat("Request                   : Reimburse (Refund 50%)\n")
          cat("-------------------------------------------------------------\n")
        }
      }
      cat("\n")
    }
  })
}

# Run the app
shinyApp(ui = ui, server = server)


